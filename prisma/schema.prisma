// Prisma schema for task-pool
// On deploy: change provider to "postgresql" and point DATABASE_URL at Neon/Supabase.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- NextAuth tables (Prisma adapter) ----
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---- Application tables ----
// Status values (stored as String for portability):
//   Role:             "SUPER_ADMIN" | "ADMIN" | "MEMBER"
//   TaskStatus:       "OPEN" | "CLAIMED" | "SUBMITTED" | "APPROVED" | "REJECTED" | "ARCHIVED"
//   SubmissionStatus: "PENDING" | "APPROVED" | "REJECTED"
//   Contribution:     "CROSS_TEAM" | "PROCESS" | "KNOWLEDGE" | "FIREFIGHT" | "EXTERNAL" | "GROWTH" | "OTHER"
//   PositionLevel:    "EXECUTIVE" | "MANAGER" | "STAFF"
//   FAQCategory:      "TASK_POOL" | "COMP" | "PROCESS" | "OTHER"
//   NotificationKind: "TASK_PUBLISHED" | "SUBMISSION"
//   NotificationStatus:"SENT" | "FAILED" | "NOT_CONFIGURED"
//   RewardMethod:     "CASH" | "TRANSFER" | "VOUCHER" | "IN_KIND" | "POINTS_ONLY" | "OTHER"
//   RewardStatus:     "PENDING" | "ISSUED" | "ACKNOWLEDGED" | "DISPUTED" | "CANCELLED"
//   PenaltyStatus:    "ACTIVE" | "REVOKED"
//   ReportType:       "WEEKLY" | "MONTHLY"
//   ReportStatus:     "PENDING" | "SUBMITTED" | "LATE"
//   FolderVisibility: "PUBLIC" | "DEPARTMENT" | "PRIVATE"
//   DepartmentRole:   "LEAD" | "MEMBER"
//   ApprovalCategory: "LEAVE" | "EXPENSE" | "TRAVEL" | "PROCUREMENT" | "STAMP" | "OTHER"
//   ApprovalStatus:   "IN_PROGRESS" | "APPROVED" | "REJECTED" | "CANCELLED"
//   ApprovalStepKind: "START" | "APPROVAL" | "CC" | "END"
//   ApprovalStepMode: "ALL" (会签) | "ANY" (或签)
//   ApprovalDecision: "APPROVED" | "REJECTED" | "TRANSFERRED"

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  emailVerified      DateTime?
  image              String?
  role               String    @default("MEMBER") // "SUPER_ADMIN" | "ADMIN" | "MEMBER"
  // 财务模块独立权限（与 role 正交）：
  //   null     = 无任何财务权限（默认 · 大多数员工 · /finance 入口对其隐藏）
  //   "VIEWER" = 出纳：可查看财务页 / 凭证 / 钱包 / 银行 / 活动流（只读）
  //   "EDITOR" = 财务管理员：可读写所有财务数据
  // SUPER_ADMIN 自动等同 EDITOR（无需在此字段设值）。
  // 修改本字段：仅 SUPER_ADMIN（即老板）可在 /admin/finance/access 操作。
  financeRole        String?
  active             Boolean   @default(true)
  // 假期余额（单位：天，允许 0.5 步进）。年假 = HR 每年初设定；调休 = 加班
  // 审批通过后 1:1 累积。请假类型为"年假"/"调休"时从这里扣减，其他类型
  // （事假/病假/婚丧/产陪护）不走这里。允许为负 — 借假场景管理员手动调。
  annualLeaveBalance Float     @default(0)
  compLeaveBalance   Float     @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  tasksCreated      Task[]           @relation("TaskCreator")
  tasksClaimed      Task[]           @relation("TaskClaimant")
  submissions       Submission[]
  reviewed          Submission[]     @relation("SubmissionReviewer")
  taskClaims        TaskClaim[]
  rewardsReceived   RewardIssuance[] @relation("RewardRecipient")
  rewardsIssued     RewardIssuance[] @relation("RewardIssuer")
  penaltiesReceived Penalty[]        @relation("PenaltyTarget")
  penaltiesIssued   Penalty[]        @relation("PenaltyIssuer")
  penaltiesRevoked  Penalty[]        @relation("PenaltyRevoker")

  departments          DepartmentMembership[]
  departmentsLed       Department[]           @relation("DepartmentLead")
  announcementsCreated Announcement[]         @relation("AnnouncementAuthor")
  announcementReadings AnnouncementReading[]
  reports              Report[]               @relation("ReportAuthor")
  reportsReceived      Report[]               @relation("ReportRecipient")
  foldersCreated       Folder[]               @relation("FolderCreator")
  folderMemberships    FolderMember[]

  approvalTplsCreated   ApprovalTemplate[] @relation("ApprovalTplAuthor")
  approvalsInitiated    ApprovalInstance[] @relation("ApprovalInitiator")
  approvalStepsAssigned ApprovalStep[]     @relation("ApprovalStepAssignee")

  leaveLedgerAsSubject LeaveBalanceLedger[] @relation("LeaveLedgerUser")
  leaveLedgerAsActor   LeaveBalanceLedger[] @relation("LeaveLedgerActor")

  docsCreated    Doc[]        @relation("DocCreator")
  docsUpdated    Doc[]        @relation("DocLastEditor")
  docMemberships DocMember[]
  docVersions    DocVersion[] @relation("DocVersionAuthor")

  // 财务模块反向关系
  walletsHeld     CryptoWallet[]          @relation("WalletHolder")
  payrollProfile  EmployeePayrollProfile? @relation("PayrollProfile")
  vouchersCreated Voucher[]               @relation("VoucherCreator")
  vouchersPosted  Voucher[]               @relation("VoucherPoster")

  // 行政部模块反向关系
  adminLicensesResponsible AdminLicense[]            @relation("AdminLicenseResponsible")
  adminLicensesCreated     AdminLicense[]            @relation("AdminLicenseCreator")
  adminAssetsResponsible   AdminFixedAsset[]         @relation("AdminAssetResponsible")
  adminAssetsCreated       AdminFixedAsset[]         @relation("AdminAssetCreator")
  adminReservations        AdminMeetingReservation[] @relation("AdminMeetingReservationBookedBy")
  adminItTicketsReported   AdminItTicket[]           @relation("AdminItTicketReporter")
  adminItTicketsHandled    AdminItTicket[]           @relation("AdminItTicketHandler")
  adminEmergencyDrills     AdminEmergencyDrill[]     @relation("AdminEmergencyDrillConductor")
  adminInspections         AdminInspection[]         @relation("AdminInspectionInspector")

  // LTY 法务部反向关系
  ltyLegalRequestsCreated  LtyLegalRequest[] @relation("LtyLegalRequestRequester")
  ltyLegalRequestsAssigned LtyLegalRequest[] @relation("LtyLegalRequestAssignee")

  // MC 法务部反向关系（物理隔离 — MC Markets 数据红线，绝不与 LTY 共表）
  mcLegalRequestsCreated  McLegalRequest[] @relation("McLegalRequestRequester")
  mcLegalRequestsAssigned McLegalRequest[] @relation("McLegalRequestAssignee")

  // HR 部反向关系
  hrEmployeeProfile      HrEmployeeProfile?    @relation("HrEmployeeProfileUser")
  hrPositionsLed         HrPosition[]          @relation("HrPositionLead")
  hrCandidatesCreated    HrCandidate[]         @relation("HrCandidateCreator")
  hrPerformanceReceived  HrPerformanceReview[] @relation("HrPerformanceReviewSubject")
  hrPerformanceEvaluated HrPerformanceReview[] @relation("HrPerformanceReviewEvaluator")
  hrPrivateMsgsSent      HrPrivateMessage[]    @relation("HrPrivateMessageSender")
  hrPrivateMsgsReplied   HrPrivateMessage[]    @relation("HrPrivateMessageHr")

  // 出纳部反向关系（PR F · 增量层）
  cashierTodosOwned      CashierTodo[]               @relation("CashierTodoOwner")
  cashierReimbApplied    CashierReimbursement[]      @relation("CashierReimbApplicant")
  cashierReimbApproved   CashierReimbursement[]      @relation("CashierReimbApprover")
  cashierReconTasksOwned CashierReconciliationTask[] @relation("CashierReconTaskOwner")
  cashierComplianceOwned CashierComplianceEntry[]    @relation("CashierComplianceResponsible")
}

// Audit trail for every change to a user's leave balances. Each entry is one
// delta (positive = credit, negative = debit). source tells us whether it
// was manual admin input, an auto-deduction from an APPROVED leave, or an
// auto-credit from an APPROVED overtime. approvalInstanceId is unique per
// pool so a re-run of the same approval never double-applies.
model LeaveBalanceLedger {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation("LeaveLedgerUser", fields: [userId], references: [id], onDelete: Cascade)
  pool               String // "ANNUAL" | "COMP"
  deltaDays          Float // signed; negative for deductions
  balanceAfter       Float // snapshot of the pool after apply
  source             String // "ADMIN_SET" | "LEAVE_APPROVED" | "OVERTIME_APPROVED" | "ADMIN_ADJUST"
  note               String?
  approvalInstanceId String? // null for manual admin actions
  actorId            String?
  actor              User?    @relation("LeaveLedgerActor", fields: [actorId], references: [id])
  createdAt          DateTime @default(now())

  @@unique([approvalInstanceId, pool])
  @@index([userId, pool, createdAt])
}

model Task {
  id           String    @id @default(cuid())
  title        String
  description  String
  reward       String? // free-form reward text ("￥100" / "奶茶一杯" 等)
  // Default / advertised points for this task. Supports decimals so admins
  // can post 7.5-pt tasks. Actual award lives on Submission.awardedPoints
  // (reviewer can grant partial credit when work is partially complete).
  points       Float     @default(10)
  priority     String    @default("NORMAL") // see enum comment above
  contribution String    @default("OTHER") // see Contribution enum; marks task as "额外贡献" — not a core duty
  status       String    @default("OPEN")
  deadline     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Single-claim (default) uses claimantId. Multi-claim uses TaskClaim rows;
  // when a winning submission is approved, claimantId is set to the winner so
  // leaderboard/stats continue to work unchanged.
  allowMultiClaim Boolean @default(false)

  creatorId String
  creator   User   @relation("TaskCreator", fields: [creatorId], references: [id])

  claimantId String?
  claimant   User?     @relation("TaskClaimant", fields: [claimantId], references: [id])
  claimedAt  DateTime?

  submissions Submission[]
  attachments Attachment[]     @relation("TaskAttachments")
  claims      TaskClaim[]
  rewards     RewardIssuance[]
  penalties   Penalty[]
}

// Junction for multi-claim tasks — each row is one member who has committed to
// work on the task. Released rows have releasedAt set (kept for audit).
model TaskClaim {
  id         String    @id @default(cuid())
  taskId     String
  task       Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  claimedAt  DateTime  @default(now())
  releasedAt DateTime?

  @@unique([taskId, userId])
  @@index([userId])
}

// Per-kind notification config. Rows are auto-created by the app on first
// send if missing. Admins can toggle a kind off entirely or add "extra
// recipient" user ids that should always be cc'd on that kind, on top of
// whatever the code's default audience is.
model NotificationSetting {
  id           String   @id @default(cuid())
  kind         String   @unique // e.g. "TASK_PUBLISHED" | "ANNOUNCEMENT" | ...
  enabled      Boolean  @default(true)
  extraUserIds String   @default("[]") // JSON array of user ids to always cc
  note         String? // admin's own label / memo
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Audit log for outbound notifications — every attempt (success or failure)
// is recorded so we never silently drop a publish email. Admin can resend.
model NotificationLog {
  id         String   @id @default(cuid())
  kind       String // "TASK_PUBLISHED" | "SUBMISSION"
  taskId     String?
  subject    String
  recipients Int
  status     String // "SENT" | "FAILED" | "NOT_CONFIGURED"
  attempts   Int      @default(1)
  error      String?
  createdAt  DateTime @default(now())

  @@index([kind, createdAt])
  @@index([taskId])
}

model Submission {
  id            String    @id @default(cuid())
  taskId        String
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  note          String // submitter's description of work done
  // PENDING | APPROVED | REJECTED | REVISION_REQUESTED (退回让对方修改后重交)
  status        String    @default("PENDING")
  // Actual points granted by reviewer at approval time. Decimal-aware so
  // admins can hand out partial credit (e.g. 12.5 / 20). Null when
  // pending or rejected. Falls back to task.points if reviewer didn't
  // touch the slider — preserves old behaviour.
  awardedPoints Float?
  reviewerId    String?
  reviewer      User?     @relation("SubmissionReviewer", fields: [reviewerId], references: [id])
  reviewNote    String?
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  attachments Attachment[] @relation("SubmissionAttachments")
}

model Position {
  id                   String   @id @default(cuid())
  title                String // 岗位名称，例如 "市场运营 - 增长方向"
  level                String   @default("STAFF") // EXECUTIVE | MANAGER | STAFF
  department           String? // 所属部门
  coreResponsibilities String // 本职职责（Lane A）
  kpis                 String // 考核重点
  notInTaskPool        String? // 哪些事属于本职，不进任务池（显式划界）
  order                Int      @default(0)
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  category  String   @default("TASK_POOL") // see FAQCategory enum comment
  question  String
  answer    String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attachment {
  id         String   @id @default(cuid())
  filename   String // original filename
  // storedPath: Vercel Blob URL (legacy / large files). Empty string for
  // DB-inline records — we store the bytes in `content` instead so admins
  // don't have to configure cloud storage for the basic flow.
  storedPath String
  // Inline blob (nullable). Set for records where content lives in the DB.
  // Postgres bytea; Prisma returns a Buffer / Uint8Array at runtime.
  content    Bytes?
  mimeType   String
  size       Int
  createdAt  DateTime @default(now())

  taskId       String?
  task         Task?           @relation("TaskAttachments", fields: [taskId], references: [id], onDelete: Cascade)
  submissionId String?
  submission   Submission?     @relation("SubmissionAttachments", fields: [submissionId], references: [id], onDelete: Cascade)
  rewardId     String?
  reward       RewardIssuance? @relation("RewardReceipts", fields: [rewardId], references: [id], onDelete: Cascade)

  // Shared-files module
  folderId           String?
  folder             Folder?           @relation("FolderFiles", fields: [folderId], references: [id], onDelete: SetNull)
  uploadedById       String?
  // Announcements can include attachments
  announcementId     String?
  announcement       Announcement?     @relation("AnnouncementAttachments", fields: [announcementId], references: [id], onDelete: Cascade)
  // Reports can include attachments (e.g. screenshots)
  reportId           String?
  report             Report?           @relation("ReportAttachments", fields: [reportId], references: [id], onDelete: Cascade)
  // Approval submission attachments
  approvalInstanceId String?
  approvalInstance   ApprovalInstance? @relation("ApprovalAttachments", fields: [approvalInstanceId], references: [id], onDelete: Cascade)
}

// ---- Organisation: departments ----
model Department {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  parentId    String?
  parent      Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")
  leadUserId  String?
  lead        User?        @relation("DepartmentLead", fields: [leadUserId], references: [id])
  description String?
  order       Int          @default(0)
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  memberships DepartmentMembership[]
  folders     Folder[]
  docs        Doc[]                  @relation("DepartmentDocs")

  // 财务模块反向关系
  cryptoWallets CryptoWallet[] @relation("FinanceWallets")
  bankAccounts  BankAccount[]  @relation("FinanceBankAccounts")
}

model DepartmentMembership {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         String     @default("MEMBER") // "LEAD" | "MEMBER"
  createdAt    DateTime   @default(now())

  @@unique([departmentId, userId])
  @@index([userId])
}

// ---- Announcements ----
model Announcement {
  id          String    @id @default(cuid())
  title       String
  body        String // markdown
  pinned      Boolean   @default(false)
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  createdById String
  createdBy   User      @relation("AnnouncementAuthor", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  readings    AnnouncementReading[]
  attachments Attachment[]          @relation("AnnouncementAttachments")

  @@index([publishedAt])
}

model AnnouncementReading {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now())

  @@unique([announcementId, userId])
}

// ---- Work reports (weekly / monthly) ----
// Each (user, type, periodStart) is unique so re-submitting just updates the
// existing row. Overdue rows are those where status = PENDING and dueAt < now.
model Report {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("ReportAuthor", fields: [userId], references: [id])
  type        String // "WEEKLY" | "MONTHLY"
  periodStart DateTime
  periodEnd   DateTime
  dueAt       DateTime
  submittedAt DateTime?

  // "汇报对象" — who this report is submitted to. Optional so reports
  // without an explicit recipient still work (admins see them in aggregate).
  reportToId String?
  reportTo   User?   @relation("ReportRecipient", fields: [reportToId], references: [id])

  // First time the recipient (reportTo) opened their "汇报给我的" tab with
  // this report visible. Drives the nav unread badge: null = still unread;
  // non-null = already surfaced to the recipient, no more red dot.
  readAtByReporter DateTime?

  // Structured JSON with fixed sections: done / plan / blockers / asks.
  // Stored as text for portability; UI renders via a textarea per section.
  contentDone     String?
  contentPlan     String?
  contentBlockers String?
  contentAsks     String?

  status String @default("PENDING") // "PENDING" | "SUBMITTED" | "LATE"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments Attachment[] @relation("ReportAttachments")

  @@unique([userId, type, periodStart])
  @@index([type, periodStart])
  @@index([status])
}

// ---- Shared files (folders with permission inheritance) ----
// Permissions resolve by walking up the parent chain until the first folder
// whose visibility != INHERIT, then apply that. PUBLIC = everyone with a
// session; DEPARTMENT = members of the attached department; PRIVATE = only
// explicit FolderMember rows (plus admins + creator).
model Folder {
  id           String      @id @default(cuid())
  name         String
  parentId     String?
  parent       Folder?     @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children     Folder[]    @relation("FolderHierarchy")
  visibility   String      @default("INHERIT") // "INHERIT" | "PUBLIC" | "DEPARTMENT" | "PRIVATE"
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  createdById  String
  createdBy    User        @relation("FolderCreator", fields: [createdById], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  files   Attachment[]   @relation("FolderFiles")
  members FolderMember[]

  @@index([parentId])
}

model FolderMember {
  id        String   @id @default(cuid())
  folderId  String
  folder    Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  access    String   @default("VIEW") // "VIEW" | "EDIT"
  createdAt DateTime @default(now())

  @@unique([folderId, userId])
}

// ---- Approval flows (Lark-style visual drag-and-drop) ----
// The visual layout (nodes + edges) is stored as JSON via React Flow's shape.
// When an instance is submitted, we snapshot the template's flow + the field
// definitions so later edits to the template don't rewrite history.
model ApprovalTemplate {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  icon        String? // emoji
  category    String  @default("OTHER")
  description String?
  active      Boolean @default(true)

  // React Flow JSON: { nodes: [...], edges: [...] }
  flowJson   String
  // Array of form field specs: [{ id, type, label, required, options? }]
  fieldsJson String

  createdById String
  createdBy   User     @relation("ApprovalTplAuthor", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  instances ApprovalInstance[]
}

model ApprovalInstance {
  id          String           @id @default(cuid())
  templateId  String
  template    ApprovalTemplate @relation(fields: [templateId], references: [id])
  initiatorId String
  initiator   User             @relation("ApprovalInitiator", fields: [initiatorId], references: [id])

  title  String // derived from template + a key form value
  status String @default("IN_PROGRESS")

  formJson       String
  flowSnapshot   String // frozen at submit time
  fieldsSnapshot String

  currentNodeId String? // node being processed right now

  submittedAt DateTime  @default(now())
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps       ApprovalStep[]
  attachments Attachment[]   @relation("ApprovalAttachments")
  vouchers    Voucher[]      @relation("VoucherApproval")

  // 财务报销自动化（A1，2026-05-06）—— 仅 template.slug='finance-large-payment' 时使用
  // 状态机：IN_PROGRESS → APPROVED+aiPaymentStatus=WAITING_PAYMENT → 付款凭证关联 → POSTED
  aiPaymentStatus String? // null|WAITING_PAYMENT|POSTED
  paymentProofs   String? // JSON array: [{type, hash?, txUrl?, amount, currency, recipient, txAt, attachedAt, voucherId?}]
  tgAckMessageId  Int? // bridge 发审批挂载 ack 时记下，用于老板 reply"批"/"驳"反查

  @@index([initiatorId, status])
  @@index([status, submittedAt])
  @@index([aiPaymentStatus, completedAt]) // CFO 催办用：查 WAITING_PAYMENT > 72h
  @@index([tgAckMessageId]) // bridge reply 反查
}

// One row per (node, required-approver). For a multi-approver node in "ALL"
// mode, N rows must all be APPROVED; any REJECT fails the instance. In "ANY"
// mode the first APPROVED advances; pending siblings stay for audit but are
// marked superseded.
model ApprovalStep {
  id         String           @id @default(cuid())
  instanceId String
  instance   ApprovalInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  nodeId     String
  kind       String // "START" | "APPROVAL" | "CC" | "END"
  mode       String? // "ALL" | "ANY" — null for single-approver / CC / START / END

  approverId String?
  approver   User?   @relation("ApprovalStepAssignee", fields: [approverId], references: [id])

  decision   String? // "APPROVED" | "REJECTED" | "TRANSFERRED" — null = pending
  note       String?
  decidedAt  DateTime?
  superseded Boolean   @default(false)

  createdAt DateTime @default(now())

  @@index([instanceId, nodeId])
  @@index([approverId, decision])
}

// ---- External project boards (Jira / Airtable / Lark / Notion iframes) ----
model ProjectBoard {
  id          String   @id @default(cuid())
  name        String
  iframeUrl   String
  description String?
  icon        String? // emoji or short code
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// One record per approved task. Captures what was promised, what was actually
// paid out, by whom, when, and the recipient's acknowledgement. Double-entry
// audit trail for the "任务 → 奖励发放" lifecycle.
model RewardIssuance {
  id          String @id @default(cuid())
  taskId      String
  task        Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User   @relation("RewardRecipient", fields: [recipientId], references: [id])

  // Mirrors the task's reward/points at approval time. Editable after the fact
  // (e.g. admin negotiates a bigger bonus for exceptional work) without
  // mutating the original task record.
  rewardText String? // "¥500" / "奶茶一杯" / "项目奖金 10%"
  points     Float   @default(0) // mirror Submission.awardedPoints when partial credit granted
  method     String  @default("CASH")

  status         String    @default("PENDING") // see RewardStatus enum comment
  issuedAt       DateTime?
  issuedById     String?
  issuedBy       User?     @relation("RewardIssuer", fields: [issuedById], references: [id])
  acknowledgedAt DateTime?
  note           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Required when status = CANCELLED / DISPUTED so a rejection is always
  // auditable. Shown to the recipient in their /rewards page.
  rejectReason String?

  receipts Attachment[] @relation("RewardReceipts")

  @@unique([taskId, recipientId])
  @@index([recipientId, status])
  @@index([status, createdAt])
}

// Negative counterpart to RewardIssuance. Applied when a member claimed a
// task, wasted time, and failed to deliver — or for other discipline events.
// Deducted from leaderboard net score; visible to all members so peers can
// see who is racking up failed attempts (soft social accountability).
model Penalty {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation("PenaltyTarget", fields: [userId], references: [id])
  issuedById   String
  issuedBy     User      @relation("PenaltyIssuer", fields: [issuedById], references: [id])
  taskId       String?
  task         Task?     @relation(fields: [taskId], references: [id])
  reason       String // required — why the penalty was issued
  points       Int // positive number; how many points deducted
  status       String    @default("ACTIVE") // "ACTIVE" | "REVOKED"
  revokedAt    DateTime?
  revokedById  String?
  revokedBy    User?     @relation("PenaltyRevoker", fields: [revokedById], references: [id])
  revokeReason String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, status])
  @@index([createdAt])
}

// ---- Collaborative docs (Lark/Notion-style) ----
// Each Doc is a node in a tree (parentId) so users can organise by workspace.
// bodyJson stores TipTap's JSON document; bodyText is a flattened searchable
// copy regenerated on each save. Visibility mirrors the folder sharing model.
model Doc {
  id       String  @id @default(cuid())
  title    String  @default("无标题文档")
  bodyJson String  @default("{}") // TipTap ProseMirror JSON
  bodyText String  @default("") // flattened plain text for search
  icon     String? // optional emoji the user picks
  parentId String?
  parent   Doc?    @relation("DocHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Doc[]   @relation("DocHierarchy")

  visibility   String      @default("PUBLIC") // "PUBLIC" | "DEPARTMENT" | "PRIVATE" | "INHERIT"
  departmentId String?
  department   Department? @relation("DepartmentDocs", fields: [departmentId], references: [id], onDelete: SetNull)

  creatorId    String
  creator      User    @relation("DocCreator", fields: [creatorId], references: [id])
  lastEditorId String?
  lastEditor   User?   @relation("DocLastEditor", fields: [lastEditorId], references: [id])

  members  DocMember[]
  versions DocVersion[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Soft-delete: trashed docs disappear from nav but stay 30d for recovery.
  deletedAt DateTime?

  @@index([parentId])
  @@index([visibility])
  @@index([updatedAt])
}

model DocMember {
  id        String   @id @default(cuid())
  docId     String
  doc       Doc      @relation(fields: [docId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  access    String   @default("VIEW") // "VIEW" | "EDIT"
  createdAt DateTime @default(now())

  @@unique([docId, userId])
}

// Periodic snapshot taken when the autosave debouncer flushes a change.
// Lets users see/restore previous revisions. Keep the last N per doc so we
// don't balloon the DB; older rows are pruned in a cron or on each write.
model DocVersion {
  id          String   @id @default(cuid())
  docId       String
  doc         Doc      @relation(fields: [docId], references: [id], onDelete: Cascade)
  title       String
  bodyJson    String
  createdById String
  createdBy   User     @relation("DocVersionAuthor", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([docId, createdAt])
}

// =============================================================================
// 财务模块 (Finance Module)
// =============================================================================
// 设计原则：
// - 复用 Department / User / ApprovalInstance / Attachment（不重造轮子）
// - AI 通过 ApiKey 认证调用（与 NextAuth 用户 session 并存）
// - 凭证审批走现有 ApprovalInstance（关联 Voucher.approvalInstanceId）
// - 所有 AI 写入默认 status="AI_DRAFT"，老板审批后转 "POSTED"
// - vault_path 字段保留与 Obsidian markdown 双向链接

// ---- AI/外部服务认证 ----
// 让 Coze/n8n/外部脚本通过 x-api-key header 调 /api/finance/* 接口
// hashedKey 存 sha256，明文只在创建时返回一次（NEVER stored in plaintext）
model ApiKey {
  id          String    @id @default(cuid())
  name        String // 人类可读名字，如 "凭证编制员-Coze-Plugin"
  hashedKey   String    @unique
  keyPrefix   String // 前 8 位明文（用于在审计日志中识别哪个 key，不会泄露完整 key）
  scope       String // "FINANCE_AI:voucher_clerk" | "FINANCE_AI:chain_bookkeeper" | ... | "FINANCE_ADMIN"
  active      Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  revokedById String?
  createdById String?
  createdAt   DateTime  @default(now())

  activityLogs AiActivityLog[]

  @@index([scope, active])
}

// ---- 财务主数据：钱包 ----
model CryptoWallet {
  id           String  @id @default(cuid())
  label        String // "老板主钱包"、"出纳ERC钱包"、"Aave存款户"
  chain        String // "ETH" | "TRON" | "SOL" | ...
  address      String
  holderType   String // "BOSS" | "COMPANY_CASHIER" | "EMPLOYEE" | "TREASURY" | "EXTERNAL"
  holderUserId String? // 若 holderType=EMPLOYEE 关联到 User
  holderUser   User?   @relation("WalletHolder", fields: [holderUserId], references: [id])
  purpose      String? // 自由文本描述用途
  vaultPath    String? // Obsidian wiki 链接，如 "wiki/entities/wallet_老板_主钱包.md"
  isActive     Boolean @default(true)
  // 是否允许 cron 自动归集余额 / 监控交易。
  // 老板个人钱包混着私人和公司流水 → 设 false，避免污染公司账。
  // 出纳 / 储备 / 员工工资钱包 → 默认 true，纯公司资产可放心监控。
  autoMonitor  Boolean @default(true)
  notes        String?

  departmentId String?
  department   Department? @relation("FinanceWallets", fields: [departmentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  txAsFrom         ChainTransaction[]      @relation("TxFromWallet")
  txAsTo           ChainTransaction[]      @relation("TxToWallet")
  balanceSnapshots WalletBalanceSnapshot[]

  @@unique([chain, address])
  @@index([holderType, isActive])
}

// ---- 钱包余额定时快照（cron 每日跑） ----
// 每个 (wallet, token) 一行；多 token 一条 wallet 一次 snapshot 产生 N 行。
// amount 用 string 避免 Decimal 精度损失（USDT 6 位小数、ETH 18 位）。
model WalletBalanceSnapshot {
  id       String       @id @default(cuid())
  walletId String
  wallet   CryptoWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  token         String // "ETH" | "USDT" | "USDC"
  tokenContract String? // ERC20 合约地址（ETH 主链原生币时为 null）
  amount        String // 已格式化为人类可读小数串，例如 "0.5" / "5000.123456"

  asOf   DateTime @default(now())
  source String   @default("ETHERSCAN")

  createdAt DateTime @default(now())

  @@index([walletId, token, asOf])
  @@index([asOf])
}

// ---- 财务主数据：银行账户 ----
model BankAccount {
  id            String  @id @default(cuid())
  label         String // "工商基本户" / "宁波基本户"
  bankName      String
  accountType   String // "BASIC" | "CAPITAL" | "GENERAL" | "PAYROLL" | "FX"
  accountNumber String
  currency      String // "RMB" | "HKD" | "USD"
  vaultPath     String?
  isActive      Boolean @default(true)
  notes         String?

  departmentId String?
  department   Department? @relation("FinanceBankAccounts", fields: [departmentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bankName, accountNumber])
}

// ---- 员工工资档案（扩展 User，不重复存基础信息）----
model EmployeePayrollProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation("PayrollProfile", fields: [userId], references: [id], onDelete: Cascade)

  // 员工 USDT 冷钱包地址（独立于 CryptoWallet 主数据，因为可能员工不是 User）
  cryptoAddress String?
  cryptoChain   String? @default("ETH")

  salaryCurrency      String? // "USD" | "CNY" | null=未约定
  monthlySalaryAmount Decimal? @db.Decimal(18, 2)

  signatureConfirmed Boolean   @default(false) // 老板签字确认钱包地址正确
  effectiveFrom      DateTime?
  effectiveUntil     DateTime? // 离职日

  bankAccountNumber String? // RMB 工资发放用
  bankName          String?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---- 会计凭证 ----
model Voucher {
  id            String   @id @default(cuid())
  voucherNumber String?  @unique // 老板审批后赋值，如 "V20260428-001"
  date          DateTime
  summary       String // 摘要

  debitAccount  String // 借方科目
  creditAccount String // 贷方科目
  amount        Decimal @db.Decimal(18, 2)
  currency      String // "USD" | "USDT" | "RMB" | "HKD"

  status String @default("AI_DRAFT") // "AI_DRAFT" | "BOSS_REVIEWING" | "POSTED" | "REJECTED" | "VOIDED"

  // 创建者（任一必填）
  createdByAi String? // AI role: "voucher_clerk" 等
  createdById String?
  createdBy   User?   @relation("VoucherCreator", fields: [createdById], references: [id])

  // 审批关联（复用现有 ApprovalInstance）
  approvalInstanceId String?
  approvalInstance   ApprovalInstance? @relation("VoucherApproval", fields: [approvalInstanceId], references: [id])

  postedAt   DateTime?
  postedById String?
  postedBy   User?     @relation("VoucherPoster", fields: [postedById], references: [id])

  // 与 Obsidian wiki 双向链接
  vaultPath String?

  // JSON 数组：相关链上交易 ID / 银行流水 ID（弱关联，不强约束）
  relatedTxIds  String? // "[\"tx_id_1\",\"tx_id_2\"]"
  attachmentIds String? // 同上

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, date])
  @@index([createdAt])
}

// ---- 链上交易归集 ----
model ChainTransaction {
  id        String   @id @default(cuid())
  chain     String // "ETH" | "TRON" ...
  txHash    String
  timestamp DateTime

  fromWalletId String?
  fromWallet   CryptoWallet? @relation("TxFromWallet", fields: [fromWalletId], references: [id])
  fromAddress  String // 冗余存原始地址，便于查未登记钱包

  toWalletId String?
  toWallet   CryptoWallet? @relation("TxToWallet", fields: [toWalletId], references: [id])
  toAddress  String

  amount        Decimal @db.Decimal(36, 18)
  token         String // "USDT" | "USDC" | "ETH" | ...
  tokenContract String?

  tag   String? // "MC_MARKETS_INVOICE" | "PAYROLL" | "AAVE_DEPOSIT" | ...
  notes String?

  isReconciled     Boolean         @default(false)
  reconciliationId String?
  reconciliation   Reconciliation? @relation("ReconciliationTxs", fields: [reconciliationId], references: [id])

  vaultPath   String?
  createdByAi String?
  createdAt   DateTime @default(now())

  @@unique([chain, txHash])
  @@index([timestamp])
  @@index([tag])
}

// ---- 汇率快照 ----
model FxRate {
  id          String   @id @default(cuid())
  date        DateTime
  pair        String // "USDT/HKD" | "USD/CNY" | ...
  rate        Decimal  @db.Decimal(18, 8)
  source      String // "COINGECKO" | "OKX" | "BINANCE" | "MSO" | "HKMA" | ...
  isOfficial  Boolean  @default(false) // HKMA 之类官方
  notes       String?
  createdByAi String?
  createdAt   DateTime @default(now())

  @@unique([date, pair, source])
  @@index([pair, date])
}

// ---- 三方对账 ----
model Reconciliation {
  id     String @id @default(cuid())
  period String // "2026-04"
  scope  String // "MONTHLY" | "WEEKLY" | "ADHOC"

  bankTotal   Decimal? @db.Decimal(18, 2)
  chainTotal  Decimal? @db.Decimal(36, 18)
  ledgerTotal Decimal? @db.Decimal(18, 2)

  diffAmount   Decimal? @db.Decimal(18, 2)
  diffCurrency String?

  status         String  @default("OPEN") // "OPEN" | "RESOLVED" | "ESCALATED"
  resolutionNote String?

  vaultPath   String?
  createdByAi String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  closedAt    DateTime?

  txs ChainTransaction[] @relation("ReconciliationTxs")

  @@unique([period, scope])
}

// ---- AI 活动日志（审计 + 看板活动流） ----
model AiActivityLog {
  id           String  @id @default(cuid())
  aiRole       String // "voucher_clerk" | "chain_bookkeeper" | ...
  action       String // "create_voucher" | "log_chain_tx" | "update_fx_rate" | "send_to_telegram" | ...
  status       String  @default("success") // "success" | "failed" | "pending"
  payload      String? // JSON 字符串（输入/输出摘要）
  errorMessage String?

  // 关联（任意一个，弱约束）
  voucherId          String?
  chainTransactionId String?
  reconciliationId   String?
  fxRateId           String?

  // 认证主体
  apiKeyId String?
  apiKey   ApiKey? @relation(fields: [apiKeyId], references: [id])

  // 三向分发追踪
  telegramSent     Boolean @default(false)
  vaultWritten     Boolean @default(false)
  dashboardWritten Boolean @default(true) // 自身就是看板写入

  createdAt DateTime @default(now())

  @@index([aiRole, createdAt])
  @@index([action, createdAt])
}

// ---- 知识管理部 · 看板召唤管家 ingest 任务 ----
// 老板手机点 [🤖 召唤管家] → 看板写一行 → Mac IngestWorker 轮询拉走
// → 跑 `claude -p` headless ingest → 把 result 回写 → 看板轮询读到 → 显示
model IngestRequest {
  id            String    @id @default(cuid())
  scope         String // "all_inbox" | "specific_path:..." 等
  status        String    @default("pending") // "pending" | "claimed" | "running" | "done" | "error"
  result        String? // markdown 报告（claude stdout 摘要）
  commitSha     String? // 若 claude 自己 commit 了
  errorMessage  String?
  requestedById String // User.id（弱关联）
  requestedAt   DateTime  @default(now())
  claimedAt     DateTime?
  startedAt     DateTime?
  finishedAt    DateTime?

  @@index([status, requestedAt])
}

// ---- 知识管理部 · 看板上传 → vault 中转 ----
// 老板手机上传文件 → Vercel Blob → Mac worker (bot.py 内的 BlobSync 线程) 拉到 raw/_inbox/from_dashboard/
// 下载后立刻删 blob 节约存储费用。
model PendingUpload {
  id           String    @id @default(cuid())
  blobUrl      String // Vercel Blob 公开 URL
  blobPathname String // Blob 内部路径，删 blob 时用
  filename     String // 原始文件名（前端上传时显示给老板的）
  contentType  String?
  sizeBytes    Int
  uploaderId   String // 上传人 User.id（弱关联，无 FK 避免删用户连带删上传）
  status       String    @default("pending") // "pending" | "downloaded" | "failed"
  downloadedAt DateTime?
  vaultPath    String? // 落到 vault 的相对路径，downloaded 时填
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, createdAt])
}

// =====================================================
// 行政部（Admin Dept）— 部门看板嵌入版 v1
// =====================================================
//
// Why：把外部 manus.space 行政看板（证照 / 资产 / 设施 / 应急 / 巡检 / IT 工单）
// 重新实现进 LTY 总看板，权限走 DepartmentMembership（slug='admin'）+ SUPER_ADMIN
// 自动放行。文件附件复用 PendingUpload 走 vault 路径，model 字段只存 vaultPath。

// ---- 行政 · 证照 / 合同 ----
// 营业执照、合同、资质证书等到期管理；status 派生自 expireAt 和 manual override
model AdminLicense {
  id            String    @id @default(cuid())
  type          String // "BUSINESS_LICENSE" | "CONTRACT" | "QUALIFICATION" | "CERTIFICATE" | "OTHER"
  name          String // 证照名 / 合同对方名
  identifier    String? // 证号 / 合同编号
  issuedAt      DateTime?
  expireAt      DateTime? // null = 永久有效
  status        String    @default("ACTIVE") // "ACTIVE" | "EXPIRING" | "EXPIRED" | "ARCHIVED"
  responsibleId String?
  responsible   User?     @relation("AdminLicenseResponsible", fields: [responsibleId], references: [id])
  vaultPath     String? // 扫描件落 vault 的路径
  notes         String?

  createdById String?
  createdBy   User?    @relation("AdminLicenseCreator", fields: [createdById], references: [id])
  createdByAi String? // AI role 名（如 "admin_clerk"），人工创建时为 null
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, expireAt])
  @@index([responsibleId])
}

// ---- 行政 · 固定资产 ----
model AdminFixedAsset {
  id            String    @id @default(cuid())
  assetCode     String?   @unique // "FA-YYYYMM-NNN" 老板批准时分配
  name          String
  category      String // "OFFICE_EQUIPMENT" | "FURNITURE" | "ELECTRONICS" | "OTHER"
  location      String?
  purchasedAt   DateTime?
  purchasePrice Decimal?  @db.Decimal(18, 2)
  currency      String?   @default("HKD")
  status        String    @default("IN_USE") // "IN_USE" | "IDLE" | "RETIRED" | "LOST"
  responsibleId String?
  responsible   User?     @relation("AdminAssetResponsible", fields: [responsibleId], references: [id])
  vaultPath     String?
  notes         String?

  createdById String?
  createdBy   User?    @relation("AdminAssetCreator", fields: [createdById], references: [id])
  createdByAi String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, status])
  @@index([responsibleId])
}

// ---- 行政 · 办公用品库存（轻量计件） ----
model AdminSupply {
  id           String   @id @default(cuid())
  name         String
  spec         String?
  unit         String?  @default("件")
  currentStock Int      @default(0)
  safetyStock  Int      @default(0) // 低于此值显示警报
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([currentStock, safetyStock])
}

// ---- 行政 · 会议室 ----
model AdminMeetingRoom {
  id        String   @id @default(cuid())
  name      String   @unique
  capacity  Int
  equipment String? // "投影 / 白板 / 视频会议"等
  active    Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())

  reservations AdminMeetingReservation[]
}

model AdminMeetingReservation {
  id            String           @id @default(cuid())
  roomId        String
  room          AdminMeetingRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  bookedById    String
  bookedBy      User             @relation("AdminMeetingReservationBookedBy", fields: [bookedById], references: [id])
  startAt       DateTime
  endAt         DateTime
  purpose       String?
  attendeeCount Int?
  status        String           @default("BOOKED") // "BOOKED" | "CANCELLED" | "DONE"
  createdAt     DateTime         @default(now())

  @@index([roomId, startAt])
  @@index([bookedById])
}

// ---- 行政 · IT 报修工单 ----
model AdminItTicket {
  id             String    @id @default(cuid())
  ticketNumber   String    @unique // "IT-YYYYMM-NNN"
  equipment      String
  faultDesc      String
  reporterId     String
  reporter       User      @relation("AdminItTicketReporter", fields: [reporterId], references: [id])
  reportedAt     DateTime  @default(now())
  handlerId      String?
  handler        User?     @relation("AdminItTicketHandler", fields: [handlerId], references: [id])
  status         String    @default("OPEN") // "OPEN" | "IN_PROGRESS" | "RESOLVED" | "CANCELLED"
  resolutionNote String?
  resolvedAt     DateTime?
  vaultPath      String? // 截图等附件 vault 路径
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, reportedAt])
  @@index([reporterId])
}

// ---- 行政 · 应急演练记录 ----
model AdminEmergencyDrill {
  id            String   @id @default(cuid())
  drillType     String // "FIRE" | "MEDICAL" | "POWER_OUTAGE" | "DATA_BREACH" | "OTHER"
  conductedAt   DateTime
  participants  Int      @default(0)
  findings      String?
  reportPath    String? // vault 路径
  conductedById String?
  conductedBy   User?    @relation("AdminEmergencyDrillConductor", fields: [conductedById], references: [id])
  createdAt     DateTime @default(now())

  @@index([drillType, conductedAt])
}

// ---- 行政 · 月度巡检 ----
model AdminInspection {
  id             String   @id @default(cuid())
  month          String // "2026-05" 唯一标识月度
  inspectionType String // "FIRE_SAFETY" | "ELECTRICAL" | "GENERAL"
  inspectorId    String
  inspector      User     @relation("AdminInspectionInspector", fields: [inspectorId], references: [id])
  issuesFound    String?
  status         String   @default("PENDING") // "PENDING" | "PASS" | "ISSUES_FOUND"
  reportPath     String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([month, inspectionType])
}

// =====================================================
// 法务部 · LTY 自家
// =====================================================
//
// 跟 MC 法务部 schema 完全镜像，但物理隔离两套表 ——
// MC Markets 数据红线：绝不与 LTY 自家数据共表/混库。
//
// 字段灵感来自 dist-two-beta-41.vercel.app（旭珑法务合规管理看板）：
// 需求 = 业务部门发起的法务工单，要 LTY 法务团队处理。
// PR D 范围只做 Request CRUD；服务目录 / 通知 / AI 问答留 PR E。

model LtyLegalRequest {
  id             String    @id @default(cuid())
  title          String
  description    String?
  category       String? // "CONTRACT_REVIEW" | "IP" | "COMPLIANCE" | "DISPUTE" | "OTHER"
  priority       String    @default("NORMAL") // "LOW" | "NORMAL" | "HIGH" | "URGENT"
  status         String    @default("OPEN") // "OPEN" | "IN_PROGRESS" | "RESOLVED" | "CANCELLED"
  requesterId    String
  requester      User      @relation("LtyLegalRequestRequester", fields: [requesterId], references: [id])
  assigneeId     String?
  assignee       User?     @relation("LtyLegalRequestAssignee", fields: [assigneeId], references: [id])
  resolvedAt     DateTime?
  resolutionNote String?
  vaultPath      String? // GitHub vault 路径
  notes          String?
  createdByAi    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, priority])
  @@index([requesterId])
  @@index([assigneeId])
}

// =====================================================
// 法务部 · MC Markets 外包业务（物理隔离）
// =====================================================

model McLegalRequest {
  id             String    @id @default(cuid())
  title          String
  description    String?
  category       String?
  priority       String    @default("NORMAL")
  status         String    @default("OPEN")
  requesterId    String
  requester      User      @relation("McLegalRequestRequester", fields: [requesterId], references: [id])
  assigneeId     String?
  assignee       User?     @relation("McLegalRequestAssignee", fields: [assigneeId], references: [id])
  resolvedAt     DateTime?
  resolutionNote String?
  // 注意：vaultPath 不与 LTY vault 共享 —— MC Markets 数据走单独 vault 通道
  vaultPath      String?
  notes          String?
  createdByAi    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, priority])
  @@index([requesterId])
  @@index([assigneeId])
}

// =====================================================
// HR 部 · 人事管理（PR E）
// =====================================================
//
// 复用现有 LTY 模块（不重做）：
// - 账号管理 → /admin/users
// - 事务流程（请假/报销/加班/转正/补卡）→ /approvals + ApprovalTemplate
// - 任务中心（HR 发任务）→ /dashboard 任务池
// - 员工手册 → /docs
// - 公开问答 → /faq
// - 公司制度 → /announcements
//
// HR 特有新建：在招岗位 / 候选人 / 员工档案（含试用期 + 证件到期监控）/
// 绩效评估（季度窗口）/ 私信 HR。
// 试用期 30 天内 + 证件 60 天内 = HR 主页 banner 自动派生，不依赖 AI。

// ---- HR · 在招岗位 ----
model HrPosition {
  id          String    @id @default(cuid())
  title       String
  department  String? // 自由文本部门名（不强制 FK 到 Department）
  status      String    @default("RECRUITING") // "RECRUITING" | "PAUSED" | "CLOSED"
  headcount   Int       @default(1)
  description String?
  deadline    DateTime?
  leadId      String?
  lead        User?     @relation("HrPositionLead", fields: [leadId], references: [id])
  notes       String?
  createdByAi String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  candidates HrCandidate[]

  @@index([status, deadline])
}

// ---- HR · 候选人（招聘漏斗）----
model HrCandidate {
  id          String      @id @default(cuid())
  name        String
  phone       String?
  email       String?
  positionId  String?
  position    HrPosition? @relation(fields: [positionId], references: [id], onDelete: SetNull)
  stage       String      @default("APPLIED") // "APPLIED" | "SCREENING" | "INTERVIEWING" | "OFFER" | "HIRED" | "REJECTED"
  appliedAt   DateTime    @default(now())
  resumeUrl   String? // vault path / blob URL
  notes       String?
  createdById String?
  createdBy   User?       @relation("HrCandidateCreator", fields: [createdById], references: [id])
  createdByAi String?
  updatedAt   DateTime    @updatedAt

  @@index([stage, appliedAt])
  @@index([positionId])
}

// ---- HR · 员工档案 ----
// 跟 User 表一对一关联（每个 active LTY User 有一份 HR profile）。
// 试用期到期 30 天内 + 证件到期 60 天内 = HR 主页 banner 监控源。
model HrEmployeeProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation("HrEmployeeProfileUser", fields: [userId], references: [id], onDelete: Cascade)
  department     String?
  positionTitle  String? // 职位名（不一定等于 User.role 系统级别）
  employmentType String    @default("FULL_TIME") // "FULL_TIME" | "PART_TIME" | "INTERN" | "CONTRACTOR"
  workLocation   String    @default("ONSITE") // "ONSITE" | "REMOTE"
  hireDate       DateTime?
  probationEnd   DateTime? // 试用期到期 → 30 天内进 banner
  contractEnd    DateTime? // 合同到期
  idType         String? // "ID_CARD" | "PASSPORT" | "WORK_PERMIT"
  idNumber       String? // 加密存？v1 明文存（仅 SUPER_ADMIN + HR LEAD 可见）
  idExpireAt     DateTime? // 证件到期 → 60 天内进 banner
  status         String    @default("ACTIVE") // "ACTIVE" | "PROBATION" | "RESIGNED"
  resignedAt     DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, probationEnd])
  @@index([idExpireAt])
}

// ---- HR · 绩效评估 ----
// 季度窗口：goal_setting → in_progress → evaluating → published → promoted
// PR E 暂不做完整流程 UI，只建表 + 列表入口；详细评估 v1.1 加。
model HrPerformanceReview {
  id          String    @id @default(cuid())
  period      String // "2026-Q2"
  phase       String    @default("GOAL_SETTING") // "GOAL_SETTING" | "IN_PROGRESS" | "EVALUATING" | "PUBLISHED" | "PROMOTED"
  subjectId   String
  subject     User      @relation("HrPerformanceReviewSubject", fields: [subjectId], references: [id])
  evaluatorId String?
  evaluator   User?     @relation("HrPerformanceReviewEvaluator", fields: [evaluatorId], references: [id])
  grade       String? // "S" | "A" | "B" | "C" | null（待评估）
  score       Int?
  goals       String? // 目标设定阶段写
  selfReview  String? // 自评
  managerNote String? // 上级评
  hrFinalNote String? // HR 综合
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([period, subjectId])
  @@index([period, phase])
  @@index([subjectId])
}

// ---- HR · 私信 HR ----
// 员工 → HR 一对一私密咨询（公开问答 /faq 的姊妹功能，但仅当事人 + HR 可见）
// PR E 建表 + 简单消息流；威胁/敏感话题升级到 SUPER_ADMIN 留 v1.1。
model HrPrivateMessage {
  id          String    @id @default(cuid())
  threadId    String // 同一对话 thread 共享 id（cuid）
  senderId    String
  sender      User      @relation("HrPrivateMessageSender", fields: [senderId], references: [id])
  // 当 HR 回复时填 HR userId；员工发起时为 null
  hrReplyById String?
  hrReplyBy   User?     @relation("HrPrivateMessageHr", fields: [hrReplyById], references: [id])
  body        String
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([threadId, createdAt])
  @@index([senderId])
}

// =====================================================
// 出纳部业务表（Cashier · PR F · 增量层）
// =====================================================
//
// PR #41 仅做 Department seed + UI 框架，业务表留 PR I/F。本 PR（F）
// 接出纳 manus 看板的 7 张子页所需 schema：
//   待处理 / 报销 / 对账 / 合规台账 / 预算 / 月度结算（工资单复用 EmployeePayrollProfile）
//
// ⭐ 双层结构铁律（feedback_lty_legal_dual_layer）：
//   合规台账条目 dualLayer 字段 = REAL/COMPLIANCE/BOTH，决定要不要进真实账。

// 出纳 · 待处理任务（页面：待处理）
model CashierTodo {
  id          String    @id @default(cuid())
  title       String
  detail      String?
  priority    String    @default("MEDIUM") // "LOW" | "MEDIUM" | "HIGH" | "URGENT"
  status      String    @default("OPEN") // "OPEN" | "IN_PROGRESS" | "DONE" | "CANCELLED"
  ownerId     String?
  owner       User?     @relation("CashierTodoOwner", fields: [ownerId], references: [id])
  dueAt       DateTime?
  doneAt      DateTime?
  notes       String?
  createdByAi String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, dueAt])
  @@index([ownerId])
}

// 出纳 · 报销申请（页面：报销）
// 跟 /finance ApprovalInstance 不混 —— 这是出纳页"小/中/大额"轻量入口，
// approvalInstanceId 弱关联到走重审批的实例（仅大额报销用）。
model CashierReimbursement {
  id                 String    @id @default(cuid())
  applicantId        String
  applicant          User      @relation("CashierReimbApplicant", fields: [applicantId], references: [id])
  category           String // "TRAVEL" | "MEAL" | "OFFICE" | "TRAINING" | "OTHER"
  title              String
  amount             Decimal   @db.Decimal(18, 2)
  currency           String    @default("CNY") // "HKD" | "CNY" | "USD"
  occurredOn         DateTime?
  department         String?
  reason             String?
  receiptVaultPath   String?
  status             String    @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED" | "PAID" | "CANCELLED"
  approvedById       String?
  approvedBy         User?     @relation("CashierReimbApprover", fields: [approvedById], references: [id])
  approvedAt         DateTime?
  paidAt             DateTime?
  rejectReason       String?
  approvalInstanceId String?
  notes              String?
  createdByAi        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([applicantId, status])
  @@index([status, createdAt])
  @@index([category, occurredOn])
}

// 出纳 · 对账任务（页面：对账）
// 周期性对账"该做什么"任务池（投放 / 代理 / 平台手续费 / 工资社保 / 银行 / 税务）。
// 区别于 finance.Reconciliation（那个是对账"记录结果"）。
model CashierReconciliationTask {
  id             String    @id @default(cuid())
  title          String // "投放渠道对账（Google/Meta/抖音）"
  reconType      String // "AD_CHANNEL" | "AGENT_REBATE" | "PLATFORM_FEE" | "PAYROLL_SOCIAL" | "BANK_DEPOSIT" | "TAX_FILING" | "OTHER"
  cycle          String // "WEEKLY" | "MONTHLY" | "QUARTERLY" | "ANNUAL"
  ownerRole      String? // 自由文本 "市场运营专员" / "财务专员" / "人事专员" / "CFO"
  ownerId        String?
  owner          User?     @relation("CashierReconTaskOwner", fields: [ownerId], references: [id])
  description    String?
  dueAt          DateTime
  status         String    @default("OPEN") // "OPEN" | "IN_PROGRESS" | "DONE" | "WARNING"
  completedAt    DateTime?
  completionNote String?
  notes          String?
  createdByAi    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, dueAt])
  @@index([reconType, dueAt])
}

// 出纳 · 合规台账（页面：合规台账）
// 5 子分类：税务申报 / 证照管理 / 银行账户 / 交易所账户 / 固定资产
// ⭐ dualLayer：REAL=链上真实业务 / COMPLIANCE=书面合规外壳 / BOTH=两本都进
//   AI 默认 REAL，老板手工切到 COMPLIANCE 防 ledger 污染。
model CashierComplianceEntry {
  id              String    @id @default(cuid())
  category        String // "TAX" | "LICENSE" | "BANK_ACCOUNT" | "EXCHANGE_ACCOUNT" | "FIXED_ASSET"
  name            String
  identifier      String? // 税号 / 证号 / 账号 / 资产编号
  cycle           String? // "MONTHLY" | "QUARTERLY" | "ANNUAL" | "ADHOC"
  nextDueAt       DateTime?
  responsibleId   String?
  responsible     User?     @relation("CashierComplianceResponsible", fields: [responsibleId], references: [id])
  responsibleName String? // 自由文本 fallback（manus.space 不要求账号绑定）
  dualLayer       String    @default("REAL") // ⭐ "REAL" | "COMPLIANCE" | "BOTH"
  status          String    @default("ACTIVE") // "ACTIVE" | "EXPIRING" | "EXPIRED" | "ARCHIVED"
  vaultPath       String?
  notes           String?
  createdByAi     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([category, status])
  @@index([category, nextDueAt])
  @@index([dualLayer]) // 老板批查"哪些是合规外壳"
}

// 出纳 · 预算（页面：预算管理） · v1.1 UI
model CashierBudget {
  id           String   @id @default(cuid())
  fiscalYear   Int
  month        Int? // 1-12，null = 整年
  category     String
  department   String?
  planAmount   Decimal  @db.Decimal(18, 2)
  currency     String   @default("USD")
  actualAmount Decimal? @db.Decimal(18, 2)
  notes        String?
  createdById  String?
  createdByAi  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([fiscalYear, month, category, department, currency])
  @@index([fiscalYear, month])
}

// 出纳 · 月度结算（页面：月度结算） · v1.1 UI
model CashierMonthlySettlement {
  id                 String    @id @default(cuid())
  period             String    @unique // "2026-05"
  reimbursementTotal Decimal?  @db.Decimal(18, 2)
  payrollTotal       Decimal?  @db.Decimal(18, 2)
  incomeTotal        Decimal?  @db.Decimal(18, 2)
  expenseTotal       Decimal?  @db.Decimal(18, 2)
  netProfit          Decimal?  @db.Decimal(18, 2)
  currency           String    @default("USD")
  status             String    @default("DRAFT") // "DRAFT" | "FINAL" | "REOPENED"
  generatedAt        DateTime?
  generatedById      String?
  notes              String?
  createdByAi        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}
