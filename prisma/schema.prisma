// Prisma schema for task-pool
// On deploy: change provider to "postgresql" and point DATABASE_URL at Neon/Supabase.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- NextAuth tables (Prisma adapter) ----
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---- Application tables ----
// Status values (stored as String for portability):
//   Role:             "SUPER_ADMIN" | "ADMIN" | "MEMBER"
//   TaskStatus:       "OPEN" | "CLAIMED" | "SUBMITTED" | "APPROVED" | "REJECTED" | "ARCHIVED"
//   SubmissionStatus: "PENDING" | "APPROVED" | "REJECTED"
//   Contribution:     "CROSS_TEAM" | "PROCESS" | "KNOWLEDGE" | "FIREFIGHT" | "EXTERNAL" | "GROWTH" | "OTHER"
//   PositionLevel:    "EXECUTIVE" | "MANAGER" | "STAFF"
//   FAQCategory:      "TASK_POOL" | "COMP" | "PROCESS" | "OTHER"
//   NotificationKind: "TASK_PUBLISHED" | "SUBMISSION"
//   NotificationStatus:"SENT" | "FAILED" | "NOT_CONFIGURED"
//   RewardMethod:     "CASH" | "TRANSFER" | "VOUCHER" | "IN_KIND" | "POINTS_ONLY" | "OTHER"
//   RewardStatus:     "PENDING" | "ISSUED" | "ACKNOWLEDGED" | "DISPUTED" | "CANCELLED"
//   PenaltyStatus:    "ACTIVE" | "REVOKED"
//   ReportType:       "WEEKLY" | "MONTHLY"
//   ReportStatus:     "PENDING" | "SUBMITTED" | "LATE"
//   FolderVisibility: "PUBLIC" | "DEPARTMENT" | "PRIVATE"
//   DepartmentRole:   "LEAD" | "MEMBER"
//   ApprovalCategory: "LEAVE" | "EXPENSE" | "TRAVEL" | "PROCUREMENT" | "STAMP" | "OTHER"
//   ApprovalStatus:   "IN_PROGRESS" | "APPROVED" | "REJECTED" | "CANCELLED"
//   ApprovalStepKind: "START" | "APPROVAL" | "CC" | "END"
//   ApprovalStepMode: "ALL" (会签) | "ANY" (或签)
//   ApprovalDecision: "APPROVED" | "REJECTED" | "TRANSFERRED"

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("MEMBER") // "SUPER_ADMIN" | "ADMIN" | "MEMBER"
  active        Boolean   @default(true)
  // 假期余额（单位：天，允许 0.5 步进）。年假 = HR 每年初设定；调休 = 加班
  // 审批通过后 1:1 累积。请假类型为"年假"/"调休"时从这里扣减，其他类型
  // （事假/病假/婚丧/产陪护）不走这里。允许为负 — 借假场景管理员手动调。
  annualLeaveBalance Float  @default(0)
  compLeaveBalance   Float  @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  tasksCreated     Task[]            @relation("TaskCreator")
  tasksClaimed     Task[]            @relation("TaskClaimant")
  submissions      Submission[]
  reviewed         Submission[]      @relation("SubmissionReviewer")
  taskClaims       TaskClaim[]
  rewardsReceived  RewardIssuance[]  @relation("RewardRecipient")
  rewardsIssued    RewardIssuance[]  @relation("RewardIssuer")
  penaltiesReceived Penalty[]        @relation("PenaltyTarget")
  penaltiesIssued  Penalty[]         @relation("PenaltyIssuer")
  penaltiesRevoked Penalty[]         @relation("PenaltyRevoker")

  departments          DepartmentMembership[]
  departmentsLed       Department[]           @relation("DepartmentLead")
  announcementsCreated Announcement[]         @relation("AnnouncementAuthor")
  announcementReadings AnnouncementReading[]
  reports              Report[]               @relation("ReportAuthor")
  reportsReceived      Report[]               @relation("ReportRecipient")
  foldersCreated       Folder[]               @relation("FolderCreator")
  folderMemberships    FolderMember[]

  approvalTplsCreated   ApprovalTemplate[]    @relation("ApprovalTplAuthor")
  approvalsInitiated    ApprovalInstance[]    @relation("ApprovalInitiator")
  approvalStepsAssigned ApprovalStep[]        @relation("ApprovalStepAssignee")

  leaveLedgerAsSubject  LeaveBalanceLedger[]  @relation("LeaveLedgerUser")
  leaveLedgerAsActor    LeaveBalanceLedger[]  @relation("LeaveLedgerActor")

  docsCreated           Doc[]                 @relation("DocCreator")
  docsUpdated           Doc[]                 @relation("DocLastEditor")
  docMemberships        DocMember[]
  docVersions           DocVersion[]          @relation("DocVersionAuthor")
}

// Audit trail for every change to a user's leave balances. Each entry is one
// delta (positive = credit, negative = debit). source tells us whether it
// was manual admin input, an auto-deduction from an APPROVED leave, or an
// auto-credit from an APPROVED overtime. approvalInstanceId is unique per
// pool so a re-run of the same approval never double-applies.
model LeaveBalanceLedger {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation("LeaveLedgerUser", fields: [userId], references: [id], onDelete: Cascade)
  pool                String   // "ANNUAL" | "COMP"
  deltaDays           Float    // signed; negative for deductions
  balanceAfter        Float    // snapshot of the pool after apply
  source              String   // "ADMIN_SET" | "LEAVE_APPROVED" | "OVERTIME_APPROVED" | "ADMIN_ADJUST"
  note                String?
  approvalInstanceId  String?  // null for manual admin actions
  actorId             String?
  actor               User?    @relation("LeaveLedgerActor", fields: [actorId], references: [id])
  createdAt           DateTime @default(now())

  @@index([userId, pool, createdAt])
  @@unique([approvalInstanceId, pool])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String
  reward      String?    // free-form reward text ("￥100" / "奶茶一杯" 等)
  points       Int       @default(10)   // numeric score used by leaderboard
  priority     String    @default("NORMAL")   // see enum comment above
  contribution String    @default("OTHER")    // see Contribution enum; marks task as "额外贡献" — not a core duty
  status      String     @default("OPEN")
  deadline    DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Single-claim (default) uses claimantId. Multi-claim uses TaskClaim rows;
  // when a winning submission is approved, claimantId is set to the winner so
  // leaderboard/stats continue to work unchanged.
  allowMultiClaim Boolean @default(false)

  creatorId   String
  creator     User       @relation("TaskCreator", fields: [creatorId], references: [id])

  claimantId  String?
  claimant    User?      @relation("TaskClaimant", fields: [claimantId], references: [id])
  claimedAt   DateTime?

  submissions Submission[]
  attachments Attachment[] @relation("TaskAttachments")
  claims      TaskClaim[]
  rewards     RewardIssuance[]
  penalties   Penalty[]
}

// Junction for multi-claim tasks — each row is one member who has committed to
// work on the task. Released rows have releasedAt set (kept for audit).
model TaskClaim {
  id         String    @id @default(cuid())
  taskId     String
  task       Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  claimedAt  DateTime  @default(now())
  releasedAt DateTime?

  @@unique([taskId, userId])
  @@index([userId])
}

// Per-kind notification config. Rows are auto-created by the app on first
// send if missing. Admins can toggle a kind off entirely or add "extra
// recipient" user ids that should always be cc'd on that kind, on top of
// whatever the code's default audience is.
model NotificationSetting {
  id          String   @id @default(cuid())
  kind        String   @unique   // e.g. "TASK_PUBLISHED" | "ANNOUNCEMENT" | ...
  enabled     Boolean  @default(true)
  extraUserIds String  @default("[]") // JSON array of user ids to always cc
  note        String?              // admin's own label / memo
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Audit log for outbound notifications — every attempt (success or failure)
// is recorded so we never silently drop a publish email. Admin can resend.
model NotificationLog {
  id         String   @id @default(cuid())
  kind       String   // "TASK_PUBLISHED" | "SUBMISSION"
  taskId     String?
  subject    String
  recipients Int
  status     String   // "SENT" | "FAILED" | "NOT_CONFIGURED"
  attempts   Int      @default(1)
  error      String?
  createdAt  DateTime @default(now())

  @@index([kind, createdAt])
  @@index([taskId])
}

model Submission {
  id          String    @id @default(cuid())
  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  note        String    // submitter's description of work done
  status      String    @default("PENDING")
  reviewerId  String?
  reviewer    User?     @relation("SubmissionReviewer", fields: [reviewerId], references: [id])
  reviewNote  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())

  attachments Attachment[] @relation("SubmissionAttachments")
}

model Position {
  id                   String   @id @default(cuid())
  title                String   // 岗位名称，例如 "市场运营 - 增长方向"
  level                String   @default("STAFF") // EXECUTIVE | MANAGER | STAFF
  department           String?  // 所属部门
  coreResponsibilities String   // 本职职责（Lane A）
  kpis                 String   // 考核重点
  notInTaskPool        String?  // 哪些事属于本职，不进任务池（显式划界）
  order                Int      @default(0)
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  category  String   @default("TASK_POOL") // see FAQCategory enum comment
  question  String
  answer    String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attachment {
  id           String      @id @default(cuid())
  filename     String      // original filename
  // storedPath: Vercel Blob URL (legacy / large files). Empty string for
  // DB-inline records — we store the bytes in `content` instead so admins
  // don't have to configure cloud storage for the basic flow.
  storedPath   String
  // Inline blob (nullable). Set for records where content lives in the DB.
  // Postgres bytea; Prisma returns a Buffer / Uint8Array at runtime.
  content      Bytes?
  mimeType     String
  size         Int
  createdAt    DateTime    @default(now())

  taskId       String?
  task         Task?       @relation("TaskAttachments", fields: [taskId], references: [id], onDelete: Cascade)
  submissionId String?
  submission   Submission? @relation("SubmissionAttachments", fields: [submissionId], references: [id], onDelete: Cascade)
  rewardId     String?
  reward       RewardIssuance? @relation("RewardReceipts", fields: [rewardId], references: [id], onDelete: Cascade)

  // Shared-files module
  folderId     String?
  folder       Folder?     @relation("FolderFiles", fields: [folderId], references: [id], onDelete: SetNull)
  uploadedById String?
  // Announcements can include attachments
  announcementId String?
  announcement   Announcement? @relation("AnnouncementAttachments", fields: [announcementId], references: [id], onDelete: Cascade)
  // Reports can include attachments (e.g. screenshots)
  reportId     String?
  report       Report?     @relation("ReportAttachments", fields: [reportId], references: [id], onDelete: Cascade)
  // Approval submission attachments
  approvalInstanceId String?
  approvalInstance   ApprovalInstance? @relation("ApprovalAttachments", fields: [approvalInstanceId], references: [id], onDelete: Cascade)
}

// ---- Organisation: departments ----
model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  parentId    String?
  parent      Department? @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")
  leadUserId  String?
  lead        User?    @relation("DepartmentLead", fields: [leadUserId], references: [id])
  description String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships DepartmentMembership[]
  folders     Folder[]
  docs        Doc[]                  @relation("DepartmentDocs")
}

model DepartmentMembership {
  id            String   @id @default(cuid())
  departmentId  String
  department    Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          String   @default("MEMBER") // "LEAD" | "MEMBER"
  createdAt     DateTime @default(now())

  @@unique([departmentId, userId])
  @@index([userId])
}

// ---- Announcements ----
model Announcement {
  id          String   @id @default(cuid())
  title       String
  body        String    // markdown
  pinned      Boolean  @default(false)
  publishedAt DateTime @default(now())
  expiresAt   DateTime?
  createdById String
  createdBy   User     @relation("AnnouncementAuthor", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  readings    AnnouncementReading[]
  attachments Attachment[] @relation("AnnouncementAttachments")

  @@index([publishedAt])
}

model AnnouncementReading {
  id              String   @id @default(cuid())
  announcementId  String
  announcement    Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt          DateTime @default(now())

  @@unique([announcementId, userId])
}

// ---- Work reports (weekly / monthly) ----
// Each (user, type, periodStart) is unique so re-submitting just updates the
// existing row. Overdue rows are those where status = PENDING and dueAt < now.
model Report {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("ReportAuthor", fields: [userId], references: [id])
  type        String   // "WEEKLY" | "MONTHLY"
  periodStart DateTime
  periodEnd   DateTime
  dueAt       DateTime
  submittedAt DateTime?

  // "汇报对象" — who this report is submitted to. Optional so reports
  // without an explicit recipient still work (admins see them in aggregate).
  reportToId  String?
  reportTo    User?    @relation("ReportRecipient", fields: [reportToId], references: [id])

  // First time the recipient (reportTo) opened their "汇报给我的" tab with
  // this report visible. Drives the nav unread badge: null = still unread;
  // non-null = already surfaced to the recipient, no more red dot.
  readAtByReporter DateTime?

  // Structured JSON with fixed sections: done / plan / blockers / asks.
  // Stored as text for portability; UI renders via a textarea per section.
  contentDone     String?
  contentPlan     String?
  contentBlockers String?
  contentAsks     String?

  status      String   @default("PENDING") // "PENDING" | "SUBMITTED" | "LATE"

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attachments Attachment[] @relation("ReportAttachments")

  @@unique([userId, type, periodStart])
  @@index([type, periodStart])
  @@index([status])
}

// ---- Shared files (folders with permission inheritance) ----
// Permissions resolve by walking up the parent chain until the first folder
// whose visibility != INHERIT, then apply that. PUBLIC = everyone with a
// session; DEPARTMENT = members of the attached department; PRIVATE = only
// explicit FolderMember rows (plus admins + creator).
model Folder {
  id           String   @id @default(cuid())
  name         String
  parentId     String?
  parent       Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children     Folder[] @relation("FolderHierarchy")
  visibility   String   @default("INHERIT") // "INHERIT" | "PUBLIC" | "DEPARTMENT" | "PRIVATE"
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  createdById  String
  createdBy    User     @relation("FolderCreator", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  files        Attachment[]  @relation("FolderFiles")
  members      FolderMember[]

  @@index([parentId])
}

model FolderMember {
  id         String   @id @default(cuid())
  folderId   String
  folder     Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  access     String   @default("VIEW") // "VIEW" | "EDIT"
  createdAt  DateTime @default(now())

  @@unique([folderId, userId])
}

// ---- Approval flows (Lark-style visual drag-and-drop) ----
// The visual layout (nodes + edges) is stored as JSON via React Flow's shape.
// When an instance is submitted, we snapshot the template's flow + the field
// definitions so later edits to the template don't rewrite history.
model ApprovalTemplate {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  icon        String?  // emoji
  category    String   @default("OTHER")
  description String?
  active      Boolean  @default(true)

  // React Flow JSON: { nodes: [...], edges: [...] }
  flowJson    String
  // Array of form field specs: [{ id, type, label, required, options? }]
  fieldsJson  String

  createdById String
  createdBy   User     @relation("ApprovalTplAuthor", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  instances   ApprovalInstance[]
}

model ApprovalInstance {
  id             String   @id @default(cuid())
  templateId     String
  template       ApprovalTemplate @relation(fields: [templateId], references: [id])
  initiatorId    String
  initiator      User     @relation("ApprovalInitiator", fields: [initiatorId], references: [id])

  title          String   // derived from template + a key form value
  status         String   @default("IN_PROGRESS")

  formJson       String
  flowSnapshot   String   // frozen at submit time
  fieldsSnapshot String

  currentNodeId  String?  // node being processed right now

  submittedAt    DateTime @default(now())
  completedAt    DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  steps          ApprovalStep[]
  attachments    Attachment[] @relation("ApprovalAttachments")

  @@index([initiatorId, status])
  @@index([status, submittedAt])
}

// One row per (node, required-approver). For a multi-approver node in "ALL"
// mode, N rows must all be APPROVED; any REJECT fails the instance. In "ANY"
// mode the first APPROVED advances; pending siblings stay for audit but are
// marked superseded.
model ApprovalStep {
  id              String   @id @default(cuid())
  instanceId      String
  instance        ApprovalInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  nodeId          String
  kind            String   // "START" | "APPROVAL" | "CC" | "END"
  mode            String?  // "ALL" | "ANY" — null for single-approver / CC / START / END

  approverId      String?
  approver        User?    @relation("ApprovalStepAssignee", fields: [approverId], references: [id])

  decision        String?  // "APPROVED" | "REJECTED" | "TRANSFERRED" — null = pending
  note            String?
  decidedAt       DateTime?
  superseded      Boolean  @default(false)

  createdAt       DateTime @default(now())

  @@index([instanceId, nodeId])
  @@index([approverId, decision])
}

// ---- External project boards (Jira / Airtable / Lark / Notion iframes) ----
model ProjectBoard {
  id          String   @id @default(cuid())
  name        String
  iframeUrl   String
  description String?
  icon        String?  // emoji or short code
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// One record per approved task. Captures what was promised, what was actually
// paid out, by whom, when, and the recipient's acknowledgement. Double-entry
// audit trail for the "任务 → 奖励发放" lifecycle.
model RewardIssuance {
  id             String   @id @default(cuid())
  taskId         String
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  recipientId    String
  recipient      User     @relation("RewardRecipient", fields: [recipientId], references: [id])

  // Mirrors the task's reward/points at approval time. Editable after the fact
  // (e.g. admin negotiates a bigger bonus for exceptional work) without
  // mutating the original task record.
  rewardText     String?  // "¥500" / "奶茶一杯" / "项目奖金 10%"
  points         Int      @default(0)
  method         String   @default("CASH")

  status         String   @default("PENDING") // see RewardStatus enum comment
  issuedAt       DateTime?
  issuedById     String?
  issuedBy       User?    @relation("RewardIssuer", fields: [issuedById], references: [id])
  acknowledgedAt DateTime?
  note           String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Required when status = CANCELLED / DISPUTED so a rejection is always
  // auditable. Shown to the recipient in their /rewards page.
  rejectReason   String?

  receipts       Attachment[] @relation("RewardReceipts")

  @@unique([taskId, recipientId])
  @@index([recipientId, status])
  @@index([status, createdAt])
}

// Negative counterpart to RewardIssuance. Applied when a member claimed a
// task, wasted time, and failed to deliver — or for other discipline events.
// Deducted from leaderboard net score; visible to all members so peers can
// see who is racking up failed attempts (soft social accountability).
model Penalty {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation("PenaltyTarget", fields: [userId], references: [id])
  issuedById    String
  issuedBy      User     @relation("PenaltyIssuer", fields: [issuedById], references: [id])
  taskId        String?
  task          Task?    @relation(fields: [taskId], references: [id])
  reason        String        // required — why the penalty was issued
  points        Int           // positive number; how many points deducted
  status        String   @default("ACTIVE") // "ACTIVE" | "REVOKED"
  revokedAt     DateTime?
  revokedById   String?
  revokedBy     User?    @relation("PenaltyRevoker", fields: [revokedById], references: [id])
  revokeReason  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, status])
  @@index([createdAt])
}

// ---- Collaborative docs (Lark/Notion-style) ----
// Each Doc is a node in a tree (parentId) so users can organise by workspace.
// bodyJson stores TipTap's JSON document; bodyText is a flattened searchable
// copy regenerated on each save. Visibility mirrors the folder sharing model.
model Doc {
  id           String   @id @default(cuid())
  title        String   @default("无标题文档")
  bodyJson     String   @default("{}")  // TipTap ProseMirror JSON
  bodyText     String   @default("")    // flattened plain text for search
  icon         String?  // optional emoji the user picks
  parentId     String?
  parent       Doc?     @relation("DocHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     Doc[]    @relation("DocHierarchy")

  visibility   String   @default("PUBLIC")   // "PUBLIC" | "DEPARTMENT" | "PRIVATE" | "INHERIT"
  departmentId String?
  department   Department? @relation("DepartmentDocs", fields: [departmentId], references: [id], onDelete: SetNull)

  creatorId    String
  creator      User     @relation("DocCreator", fields: [creatorId], references: [id])
  lastEditorId String?
  lastEditor   User?    @relation("DocLastEditor", fields: [lastEditorId], references: [id])

  members      DocMember[]
  versions     DocVersion[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  // Soft-delete: trashed docs disappear from nav but stay 30d for recovery.
  deletedAt    DateTime?

  @@index([parentId])
  @@index([visibility])
  @@index([updatedAt])
}

model DocMember {
  id        String   @id @default(cuid())
  docId     String
  doc       Doc      @relation(fields: [docId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  access    String   @default("VIEW") // "VIEW" | "EDIT"
  createdAt DateTime @default(now())

  @@unique([docId, userId])
}

// Periodic snapshot taken when the autosave debouncer flushes a change.
// Lets users see/restore previous revisions. Keep the last N per doc so we
// don't balloon the DB; older rows are pruned in a cron or on each write.
model DocVersion {
  id          String   @id @default(cuid())
  docId       String
  doc         Doc      @relation(fields: [docId], references: [id], onDelete: Cascade)
  title       String
  bodyJson    String
  createdById String
  createdBy   User     @relation("DocVersionAuthor", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([docId, createdAt])
}
