# Postgres (Neon connection string)
DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require"

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Comma-separated Google emails that become SUPER_ADMIN on first login.
# Only the founder should be here; everyone else is managed in-app.
ADMIN_EMAILS="your-email@example.com"

# Gmail SMTP for outbound notifications. Missing these values results in the
# notification showing "NOT_CONFIGURED" in the admin notifications log.
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# Vercel Blob (auto-set by Vercel when Blob store is linked)
BLOB_READ_WRITE_TOKEN=""

# Knowledge management 部门：lty-vault repo 私有读权限
# 用 fine-grained PAT，scope: lty-vault Contents read
VAULT_GITHUB_TOKEN=""

# 看板上传 → Mac BlobSync 共享密钥（任意 32 字节随机串）
# Generate with: openssl rand -base64 32
# Mac 端 _meta/tg_bot/config.yaml 的 blob_sync.shared_secret 必须填同一个值
BLOB_SYNC_SECRET=""
